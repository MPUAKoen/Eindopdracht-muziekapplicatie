        {
          "name": "Create Lesson",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const lessonDate = new Date();",
                  "lessonDate.setDate(lessonDate.getDate() + 1);",
                  "const dd = String(lessonDate.getDate()).padStart(2, '0');",
                  "const mm = String(lessonDate.getMonth() + 1).padStart(2, '0');",
                  "const yyyy = lessonDate.getFullYear();",
                  "pm.collectionVariables.set('lessonDate', `${dd}-${mm}-${yyyy}`);"
                ]
              }
            },
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Lesson is created', function () {",
                  "  pm.response.to.have.status(201);",
                  "});",
                  "const data = pm.response.json();",
                  "pm.collectionVariables.set('lessonId', data.id);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "body": {
              "mode": "formdata",
              "formdata": [
                { "key": "instrument", "value": "Piano", "type": "text" },
                { "key": "studentId", "value": "{{studentId}}", "type": "text" },
                { "key": "lessonDate", "value": "{{lessonDate}}", "type": "text" },
                { "key": "startTime", "value": "09:00", "type": "text" },
                { "key": "endTime", "value": "09:30", "type": "text" },
                { "key": "homework", "value": "Practice scales and broken chords.", "type": "text" }
              ]
            },
            "url": {
              "raw": "{{baseUrl}}/api/lessons"
            }
          }
        },
        {
